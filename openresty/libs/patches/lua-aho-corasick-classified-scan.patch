     return Match_Tmpl<MV_LEFT_LONGEST>(buf, str, len);
 }
 
+ac_result_t
+Match_Classified(AC_Buffer* buf, const char* str, uint32 len,
+                 uint32 literal_count) {
+    unsigned char* buf_base = (unsigned char*)(buf);
+    unsigned char* root_goto = buf_base + buf->root_goto_ofst;
+    AC_Ofst* states_ofst_vect = (AC_Ofst*)(buf_base + buf->states_ofst_ofst);
+
+    AC_State* state = 0;
+    uint32 idx = 0;
+    bool anchor_seen = false;
+
+    if (likely(buf->root_goto_num != 255)) {
+        while (idx < len) {
+            unsigned char c = str[idx++];
+            if (unsigned char kid_id = root_goto[c]) {
+                state = Get_State_Addr(buf_base, states_ofst_vect, kid_id);
+                break;
+            }
+        }
+    } else {
+        idx = 1;
+        state = Get_State_Addr(buf_base, states_ofst_vect, *str);
+    }
+
+    if (state && state->is_term) {
+        unsigned int pattern_idx = state->is_term - 1;
+        if (pattern_idx < literal_count) {
+            ac_result_t r = {(int)(idx - state->depth), (int)(idx - 1),
+                             (int)pattern_idx};
+            return r;
+        }
+        anchor_seen = true;
+    }
+
+    while (idx < len && state) {
+        unsigned char c = str[idx];
+        int res;
+        bool found = Binary_Search_Input(state->input_vect, state->goto_num, c, res);
+        if (found) {
+            uint32 kid = state->first_kid + res;
+            state = Get_State_Addr(buf_base, states_ofst_vect, kid);
+            idx++;
+        } else {
+            State_ID fl = state->fail_link;
+            if (fl == 0) {
+                while (idx < len) {
+                    InputTy root_c = str[idx++];
+                    if (unsigned char kid_id = root_goto[root_c]) {
+                        state = Get_State_Addr(buf_base, states_ofst_vect, kid_id);
+                        break;
+                    }
+                }
+            } else {
+                state = Get_State_Addr(buf_base, states_ofst_vect, fl);
+            }
+        }
+
+        if (state->is_term) {
+            unsigned int pattern_idx = state->is_term - 1;
+            if (pattern_idx < literal_count) {
+                ac_result_t r = {(int)(idx - state->depth), (int)(idx - 1),
+                                 (int)pattern_idx};
+                return r;
+            }
+            anchor_seen = true;
+        }
+    }
+
+    ac_result_t r = {-1, -1, anchor_seen ? -2 : -1};
+    return r;
+}
