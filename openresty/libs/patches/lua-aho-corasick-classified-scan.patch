+static int
+lac_scan(lua_State* L) {
+    buf_header_t* ac = (buf_header_t*)lua_touserdata(L, 1);
+    if (!ac) {
+        luaL_checkudata(L, 1, tname);
+        return 0;
+    }
+
+    size_t len;
+    const char* str = luaL_checklstring(L, 2, &len);
+    lua_Integer literal_count = luaL_checkinteger(L, 3);
+    if (literal_count < 0) {
+        return luaL_error(L, "literal_count must be non-negative");
+    }
+
+    ac_result_t r = Match_Classified((AC_Buffer*)(void*)ac, str, len,
+                                     (uint32)literal_count);
+    if (r.match_begin != -1) {
+        lua_pushinteger(L, r.pattern_idx);
+        return 1;
+    }
+    if (r.pattern_idx == -2) {
+        lua_pushnil(L);
+        lua_pushboolean(L, 1);
+        return 2;
+    }
+
+    return 0;
