# Claude Gateway 环境变量配置

# ===========================================
# API 鉴权配置（必须设置）
# ===========================================
# API Token - 用于保护关键词管理接口
# 建议：至少32字符的随机字符串
# 生成方法：openssl rand -base64 32
API_TOKEN=your-super-secret-token-change-me-32chars

# ===========================================
# 上游服务配置
# ===========================================
# 上游服务地址 - Claude API 后端服务地址
# 默认：https://api.anthropic.com
# 注意：如果配置了 AUTH_ROUTE_MAP，则此配置将作为未匹配到 authorization 时的默认值
UPSTREAM_URL=https://api.anthropic.com

# Authorization 路由映射配置
# 格式：auth_token1->upstream_url1,auth_token2->upstream_url2,...
# 示例：cr_1->http://1.1.1.1:8080,cr_2->http://1.1.1.1:8080,cr_3->http://2.2.2.2:8080
# 说明：
#   - 多个 authorization 可以映射到同一个 upstream_url
#   - 请求时会从 Authorization 头中提取 token（支持 "Bearer token" 格式）
#   - 如果找到匹配的 token，则路由到对应的 upstream_url
#   - 如果未找到匹配，且未配置此项或为空，则使用 UPSTREAM_URL 作为默认值
#   - 如果未找到匹配，且配置了此项，则返回 401 错误
# 留空表示不启用此功能，所有请求都使用 UPSTREAM_URL
AUTH_ROUTE_MAP=

# ===========================================
# 网络配置
# ===========================================
# 主机端口映射
# 默认：80
HOST_PORT=80

# Docker 网络名称
# 默认：claude-gateway-network
DOCKER_NETWORK_NAME=claude-gateway-network

# Docker 网络驱动
# 可选值：bridge, overlay, macvlan
# 默认：bridge
DOCKER_NETWORK_DRIVER=bridge

# 是否使用外部网络
# 设置为 true 时，将使用已存在的外部网络
# 默认：false
DOCKER_NETWORK_EXTERNAL=false

# ===========================================
# 存储配置
# ===========================================
# 关键词文件路径（宿主机路径）
# 默认：./openresty/keywords
KEYWORDS_FILE_DIR=./openresty/keywords
