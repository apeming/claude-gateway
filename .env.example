# Claude Gateway 环境变量配置

# ===========================================
# API 鉴权配置（必须设置）
# ===========================================
# API Token - 用于保护管理接口
# 建议：至少32字符的随机字符串
# 生成方法：openssl rand -base64 32
API_TOKEN=your-super-secret-token-change-me-32chars

# ===========================================
# 动态路由配置
# ===========================================
# 是否启用动态路由
# true:  启用动态路由（严格模式）
#        - 必须提供 Authorization 头
#        - token 必须在 routes.txt 中配置
#        - 从路由文件读取配置并路由到对应后端
#        - 未匹配的 token 返回 401
# false: 禁用动态路由（默认模式）
#        - 无需 Authorization 认证
#        - 所有请求使用 UPSTREAM_URL
#        - routes.txt 被忽略
# 默认：false
ENABLE_DYNAMIC_ROUTING=false

# 默认上游服务地址
# 当 ENABLE_DYNAMIC_ROUTING=false 时使用此配置
# 当 ENABLE_DYNAMIC_ROUTING=true 时此配置被忽略
# 默认：https://api.anthropic.com
UPSTREAM_URL=https://api.anthropic.com

# ===========================================
# 网络配置
# ===========================================
# 主机绑定IP地址
# 0.0.0.0:   绑定所有网络接口（公开访问）
# 127.0.0.1: 仅本地访问
# 特定IP:    绑定到指定网络接口
# 默认：0.0.0.0
HOST_IP=0.0.0.0

# 主机端口映射
# 默认：80
HOST_PORT=80

# Docker 网络名称
# 默认：claude-gateway-network
DOCKER_NETWORK_NAME=claude-gateway-network

# Docker 网络驱动
# 可选值：bridge, overlay, macvlan
# 默认：bridge
DOCKER_NETWORK_DRIVER=bridge

# 是否使用外部网络
# 设置为 true 时，将使用已存在的外部网络
# 默认：false
DOCKER_NETWORK_EXTERNAL=false

# ===========================================
# 存储配置
# ===========================================
# 配置目录（宿主机路径）
# 包含 keywords.txt 和 routes.txt
# 默认：./openresty
CONFIG_DIR=./openresty
