# API Token（必须设置，建议至少32字符）
API_TOKEN=your-api-token-here

# 是否启用动态路由（true/false，默认false）
ENABLE_DYNAMIC_ROUTING=false

# 上游服务地址（ENABLE_DYNAMIC_ROUTING=false时使用）
UPSTREAM_URL=https://api.anthropic.com

# 主机端口映射
HOST_PORT=80

# 配置目录（宿主机，包含配置文件）
CONFIG_DIR=./openresty

# Docker网络配置
DOCKER_NETWORK_NAME=claude-gateway-network
DOCKER_NETWORK_DRIVER=bridge
DOCKER_NETWORK_EXTERNAL=false

# 数据库配置
DATABASE_URL=sqlite+aiosqlite:////app/data/gateway.db

# JWT密钥（生产环境必须修改）
SECRET_KEY=your-secret-key-change-me-in-production

# 飞书OAuth配置
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_REDIRECT_URI=http://localhost/login
